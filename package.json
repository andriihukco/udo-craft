{
  "name": "udo-craft",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:ui && npm run build:admin && npm run build:client",
    "build:admin": "npm run build --workspace=admin",
    "build:client": "npm run build --workspace=client",
    "build:shared": "npm run build --workspace=@udo-craft/shared",
    "build:ui": "npm run build --workspace=@udo-craft/ui",
    "dev": "npm run dev:admin & npm run dev:client",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:client": "npm run dev --workspace=client",
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "husky",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "turbo": "^2.0.0"
  }
}